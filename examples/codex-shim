#!/usr/bin/env bash
set -euo pipefail

KIT_ROOT="${LOCAL_AI_PREFLIGHT_KIT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
PREFLIGHT_JS="${LOCAL_AI_PREFLIGHT_JS:-${KIT_ROOT}/dist/cli.js}"
REAL_BIN="${CODEX_REAL_BIN:-}"

if [[ -z "${REAL_BIN}" ]]; then
  echo "codex-shim example: set CODEX_REAL_BIN to the real executable before use." >&2
  exit 2
fi

if [[ ! -x "${REAL_BIN}" ]]; then
  echo "codex-shim example: CODEX_REAL_BIN is not executable." >&2
  exit 127
fi

if [[ ! -f "${PREFLIGHT_JS}" ]]; then
  echo "codex-shim example: build the TypeScript preflight CLI before use." >&2
  exit 127
fi

if ! command -v node >/dev/null 2>&1; then
  echo "codex-shim example: node is required." >&2
  exit 127
fi

if node "${PREFLIGHT_JS}" --repo "$(pwd)" >/dev/null; then
  exec "${REAL_BIN}" "$@"
fi

preflight_exit="$?"
exit "${preflight_exit}"
