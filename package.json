{
  "name": "local-ai-preflight-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Local AI CLI preflight gate with a minimal TypeScript core.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sudoworks-lab/local-ai-preflight-kit.git"
  },
  "bugs": {
    "url": "https://github.com/sudoworks-lab/local-ai-preflight-kit/issues"
  },
  "homepage": "https://github.com/sudoworks-lab/local-ai-preflight-kit#readme",
  "bin": {
    "local-ai-preflight": "dist/cli.js"
  },
  "files": [
    "dist/",
    "schemas/result.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "prepack": "npm run build",
    "test": "npm run build && node --test tests/*.test.js",
    "verify": "npm run build && node --test tests/*.test.js && node dist/cli.js --help >/dev/null && node dist/cli.js --version >/dev/null && python3 tests/preflight_smoke_test.py"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
