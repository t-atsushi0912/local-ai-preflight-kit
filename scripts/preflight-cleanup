#!/usr/bin/env bash
set -euo pipefail

ROOT=""
KEEP_DAYS=14
APPLY=0
OUTPUT_FORMAT="text"
TODAY="$(date -u +%F)"
ITEMS_FILE="$(mktemp)"

cleanup_tmp() {
  rm -f -- "${ITEMS_FILE}"
}
trap cleanup_tmp EXIT

usage() {
  cat <<'EOF'
usage: scripts/preflight-cleanup --root PATH [--keep-days N|--max-age-days N] [--dry-run|--apply] [--json]

Removes old timestamped preflight run directories. Dry-run is the default.
EOF
}

record_item() {
  local action="$1"
  local path="$2"
  printf '%s\t%s\n' "${action}" "${path}" >> "${ITEMS_FILE}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --root)
      ROOT="$2"
      shift 2
      ;;
    --keep-days|--max-age-days)
      KEEP_DAYS="$2"
      shift 2
      ;;
    --apply)
      APPLY=1
      shift
      ;;
    --dry-run)
      APPLY=0
      shift
      ;;
    --json)
      OUTPUT_FORMAT="json"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "preflight-cleanup: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -z "${ROOT}" ]]; then
  echo "preflight-cleanup: --root is required." >&2
  exit 2
fi
if ! [[ "${KEEP_DAYS}" =~ ^[0-9]+$ ]]; then
  echo "preflight-cleanup: keep days must be a non-negative integer." >&2
  exit 2
fi
if [[ ! -d "${ROOT}" ]]; then
  echo "preflight-cleanup: root does not exist: ${ROOT}" >&2
  exit 1
fi

ROOT_REAL="$(cd "${ROOT}" && pwd -P)"
HOME_REAL="$(cd "${HOME}" && pwd -P)"
case "${ROOT_REAL}" in
  ""|"/"|"/tmp")
    echo "preflight-cleanup: refusing broad root: ${ROOT_REAL}" >&2
    exit 1
    ;;
esac
if [[ "${ROOT_REAL}" == "${HOME_REAL}" ]]; then
  echo "preflight-cleanup: refusing broad root: ${ROOT_REAL}" >&2
  exit 1
fi

cutoff_epoch="$(date -u -d "${TODAY} - ${KEEP_DAYS} days" +%s)"
candidate_count=0
deleted_count=0

shopt -s nullglob
for date_dir in "${ROOT_REAL}"/*; do
  base_name="$(basename "${date_dir}")"
  if [[ "${base_name}" == "latest" ]]; then
    record_item "skip_latest" "${date_dir}"
    continue
  fi
  if [[ ! -d "${date_dir}" ]]; then
    record_item "skip_non_directory" "${date_dir}"
    continue
  fi
  if [[ ! "${base_name}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    record_item "skip_unknown_date" "${date_dir}"
    continue
  fi
  if [[ "${base_name}" == "${TODAY}" ]]; then
    record_item "skip_today" "${date_dir}"
    continue
  fi
  if ! dir_epoch="$(date -u -d "${base_name}" +%s 2>/dev/null)"; then
    record_item "skip_bad_date" "${date_dir}"
    continue
  fi
  if (( dir_epoch >= cutoff_epoch )); then
    record_item "keep_recent" "${date_dir}"
    continue
  fi

  for run_dir in "${date_dir}"/*; do
    run_base="$(basename "${run_dir}")"
    if [[ ! -d "${run_dir}" || ! "${run_base}" =~ ^[0-9]{8}T[0-9]{6}Z$ ]]; then
      record_item "skip_unknown_run" "${run_dir}"
      continue
    fi
    candidate_count=$((candidate_count + 1))
    if [[ "${APPLY}" -eq 1 ]]; then
      rm -rf -- "${run_dir}"
      deleted_count=$((deleted_count + 1))
      record_item "deleted" "${run_dir}"
    else
      record_item "would_delete" "${run_dir}"
    fi
  done

  if [[ "${APPLY}" -eq 1 ]]; then
    rmdir "${date_dir}" 2>/dev/null || true
  fi
done
shopt -u nullglob

if [[ "${OUTPUT_FORMAT}" == "json" ]]; then
  python3 - "${ITEMS_FILE}" "${ROOT_REAL}" "${APPLY}" "${KEEP_DAYS}" "${candidate_count}" "${deleted_count}" <<'PY'
import json
import sys

items_path, root, apply_flag, keep_days, candidates, deleted = sys.argv[1:]
items = []
with open(items_path, "r", encoding="utf-8") as handle:
    for line in handle:
        action, path = line.rstrip("\n").split("\t", 1)
        items.append({"action": action, "path": path})
print(json.dumps({
    "root": root,
    "mode": "apply" if apply_flag == "1" else "dry-run",
    "keep_days": int(keep_days),
    "candidates": int(candidates),
    "deleted": int(deleted),
    "items": items,
}, ensure_ascii=False))
PY
else
  printf 'root=%s\n' "${ROOT_REAL}"
  printf 'mode=%s\n' "$([[ "${APPLY}" -eq 1 ]] && printf apply || printf dry-run)"
  printf 'keep_days=%s\n' "${KEEP_DAYS}"
  printf 'candidates=%s\n' "${candidate_count}"
  printf 'deleted=%s\n' "${deleted_count}"
  while IFS=$'\t' read -r action path; do
    printf '%s %s\n' "${action}" "${path}"
  done < "${ITEMS_FILE}"
fi
